---
import bio from '../data/bio.json';
---

<footer class="py-12 border-t border-slate-100 text-slate-500 text-sm">
	<div class="flex flex-col md:flex-row justify-between items-center gap-4">
		<p>© {new Date().getFullYear()} {bio.name}</p>
		<div class="flex space-x-6">
			{Object.entries(bio.socials).map(([name, url]) => (
				<a href={url} target="_blank" rel="noopener noreferrer" class="hover:text-blue-600 transition-colors capitalize">
					{name}
				</a>
			))}
		</div>
	</div>
</footer>
