---
import BaseLayout from '../layouts/BaseLayout.astro';
import PublicationCard from '../components/PublicationCard.astro';
import bio from '../data/bio.json';
import publications from '../data/publications.json';

const currentYear = new Date().getFullYear();
const tenYearsAgo = currentYear - 10;

const topPublications = publications
	.filter(pub => parseInt(pub.year) >= tenYearsAgo)
	.sort((a, b) => b.citations - a.citations)
	.slice(0, 5);

const profileImage = "http://servicosweb.cnpq.br/wspessoa/servletrecuperafoto?tipo=1&id=K4123434Y6";
---

<BaseLayout title="Home">
	<section class="mb-16">
		<div class="flex flex-col-reverse md:flex-row gap-12 items-start">
			<div class="flex-1">
				<h1 class="text-5xl font-bold mb-4 tracking-tight text-slate-900">{bio.name}</h1>
				<p class="text-xl text-slate-500 mb-8 leading-relaxed">
					{bio.title} at <span class="text-slate-900 font-medium">{bio.affiliation}</span>.
				</p>
				
				<div class="prose prose-slate prose-lg mb-8">
					<p>{bio.bio}</p>
				</div>

				<div class="flex flex-wrap gap-4">
					{Object.entries(bio.socials).map(([name, url]) => (
						<a href={url} target="_blank" rel="noopener noreferrer" class="flex items-center gap-1.5 text-sm font-bold uppercase tracking-widest text-blue-600 hover:text-blue-800 transition-colors">
							<span class="capitalize">{name}</span>
							<svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
							</svg>
						</a>
					))}
				</div>
			</div>
			<div class="w-48 h-48 md:w-64 md:h-64 bg-slate-100 rounded-2xl overflow-hidden flex-shrink-0 shadow-2xl shadow-blue-500/10">
				<img 
					src={profileImage} 
					alt={bio.name} 
					class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-500"
				/>
			</div>
		</div>
	</section>

	<section class="mb-16">
		<h2 class="text-3xl font-bold mb-8 border-b border-slate-100 pb-2">Research Interests</h2>
		<div class="flex flex-wrap gap-3">
			{bio.interests.map((interest) => (
				<span class="px-4 py-2 bg-slate-50 text-slate-700 rounded-full text-sm font-medium border border-slate-100">
					{interest}
				</span>
			))}
		</div>
	</section>

	<section>
		<div class="flex justify-between items-end mb-8 border-b border-slate-100 pb-2">
			<h2 class="text-3xl font-bold">Featured Research (Last 10 Years)</h2>
			<a href="/publications" class="text-blue-600 hover:underline text-sm font-medium">View all publications →</a>
		</div>
		<div class="divide-y divide-slate-50">
			{topPublications.map((pub) => (
				<PublicationCard {...pub} />
			))}
		</div>
	</section>
</BaseLayout>
