---
import BaseLayout from '../layouts/BaseLayout.astro';
import bio from '../data/bio.json';
---

<BaseLayout title="Contact">
	<h1 class="text-5xl font-bold mb-12 tracking-tight">Contact</h1>

	<div class="grid md:grid-cols-2 gap-12">
		<section>
			<h2 class="text-2xl font-bold mb-6 text-slate-900 border-b border-slate-100 pb-2">Get in Touch</h2>
			<div class="space-y-8">
				<div class="flex items-start gap-4">
					<div class="bg-blue-50 p-3 rounded-lg text-blue-600">
						<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
						</svg>
					</div>
					<div>
						<h3 class="font-bold text-slate-900">Email</h3>
						<a href={`mailto:${bio.contact.email}`} class="text-blue-600 hover:underline">{bio.contact.email}</a>
					</div>
				</div>

				<div class="flex items-start gap-4">
					<div class="bg-blue-50 p-3 rounded-lg text-blue-600">
						<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
						</svg>
					</div>
					<div>
						<h3 class="font-bold text-slate-900">Office Address</h3>
						<p class="text-slate-600 leading-relaxed">
							{bio.contact.address}
						</p>
					</div>
				</div>
			</div>
		</section>

		<section>
			<h2 class="text-2xl font-bold mb-6 text-slate-900 border-b border-slate-100 pb-2">Profiles</h2>
			<div class="grid grid-cols-1 gap-4">
				{Object.entries(bio.socials).map(([name, url]) => (
					<a 
						href={url} 
						target="_blank" 
						rel="noopener noreferrer" 
						class="flex items-center gap-4 p-4 bg-slate-50 rounded-xl hover:bg-blue-50 hover:text-blue-600 transition-all group"
					>
						<span class="capitalize font-medium">{name}</span>
						<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 ml-auto opacity-0 group-hover:opacity-100 transition-opacity" fill="none" viewBox="0 0 24 24" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
						</svg>
					</a>
				))}
			</div>
		</section>
	</div>
</BaseLayout>
